# Copy to `.env` and fill in. `.env` is git-ignored. The package reads these via
# config interpolation (${ENV}) — never hardcode keys in YAML or code.

# Frontier API providers (extra: [api]). Used by the agent and the simulated-user
# oracle. Only the provider(s) you actually run need a key.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub PAT for the task collector (extra: [collect]). Needs public_repo /
# read-only scope for the GraphQL + REST harvest.
GITHUB_TOKEN=

# Base URL of a running vLLM OpenAI-compatible server (extra: [serve]).
# In DAIC split-mode the GPU node serves vLLM and the harness points here, e.g.
# http://<gpu-node>:8000/v1
VLLM_BASE_URL=
